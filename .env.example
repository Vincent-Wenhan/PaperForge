# ============ LLM Provider ============
# openai | anthropic | openai_compatible
LLM_PROVIDER=openai_compatible

# OpenAI / OpenAI-Compatible
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://chat-api.westaclab.com/v1
LLM_MODEL=glm-5.2

# Anthropic
ANTHROPIC_API_KEY=

# ============ Sub-agent Models ============
# Default model for each sub-agent (falls back to LLM_MODEL if not set)
ORCHESTRATOR_MODEL=
PARSER_MODEL=
COMPOSER_MODEL=
PLANNER_MODEL=
GENERATOR_MODEL=
VERIFIER_MODEL=

# ============ Server ============
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000

# ============ Sandbox ============
MAX_SANDBOXES=3
SANDBOX_IMAGE=node:20-alpine
SANDBOX_MEM_LIMIT=1g
SANDBOX_CPU_QUOTA=50000

# ============ Storage ============
DATA_DIR=./data
DB_PATH=./data/paperforge.db
